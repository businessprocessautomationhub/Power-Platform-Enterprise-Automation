{"version":"0.3.0","body":"\nfunction main(\n\n    workbook: ExcelScript.Workbook,\n    valuesJson: string,\n    page: number\n\n) {\n    \n    const BATCH = 2000;\n    const sheet = workbook.getWorksheet(\"Sheet1\");\n    const rows: (string | number | boolean)[][] = JSON.parse(valuesJson);\n\n    // ===== BASIC VALIDATION =====\n\n    if (!rows || rows.length === 0) {\n\n        throw new Error(\"No rows received to paste\");\n\n    }\n\n    const colCount = rows[0].length;\n\n    // Clear sheet only once (page 1) *****\n\n    if (page === 1) {\n\n        sheet.getUsedRange()?.clear();\n\n    }\n\n\n    // ===== CALCULATE POSITION =====\n    // ===== WRITE =====\n    const startRow = (page - 1) * BATCH;\n    const targetRange = sheet.getRangeByIndexes(startRow, 0, rows.length, colCount);\n\n    targetRange.setValues(rows);\n\n    // ===== SIMPLE VERIFICATION (ONLY 1 CHECK) =====\n\n    const writtenRows = targetRange.getRowCount();\n\n    if (writtenRows !== rows.length) {\n\n        throw new Error(`Mismatch: expected ${rows.length}, got ${writtenRows}`);\n\n    }\n\n    console.log(`Page ${page}: ${rows.length} rows written successfully`);\n\n}","description":"","noCodeMetadata":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[{\"name\":\"valuesJson\",\"index\":0},{\"name\":\"page\",\"index\":1}],\"parameterSchema\":{\"type\":\"object\",\"required\":[\"valuesJson\",\"page\"],\"properties\":{\"valuesJson\":{\"type\":\"string\"},\"page\":{\"type\":\"number\"}}},\"returnSchema\":{\"type\":\"object\",\"properties\":{}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"},{\"name\":\"valuesJson\",\"comment\":\"\"},{\"name\":\"page\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}