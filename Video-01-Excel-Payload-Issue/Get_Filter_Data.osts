{"version":"0.3.0","body":"\nfunction main(workbook: ExcelScript.Workbook, Region: string) {\n\n    const Region_Input = Region\n    const TABLE_NAME = \"Table1\";\n    const CHUNK_SIZE = 5000;\n    const table = workbook.getTable(TABLE_NAME);\n\n    if (!table) {\n\n        console.log(\"Table not found\");\n\n        return;\n\n    }\n\n    // ===== HEADER =====\n\n    const header = table.getHeaderRowRange().getValues()[0];\n    const colCount = header.length;\n    const RegionIdx = header.indexOf(\"Region\");\n\n    console.log(RegionIdx)\n\n    if (RegionIdx < 0) {\n\n        console.log(\"Required columns missing\");\n\n        return;\n\n    }\n\n\n    // ===== RANGE =====\n\n    const fullRange = table.getRange();\n    const totalRows = fullRange.getRowCount();\n    const rowCount = totalRows - 1;\n\n    console.log(\"Total rows: \" + rowCount);\n\n    // ===== PREP OUTPUT SHEET =====\n\n    let out = workbook.getWorksheet(\"Temp_FilteredData\");\n\n    if (!out) {\n\n        out = workbook.addWorksheet(\"Temp_FilteredData\");\n\n    } else {\n\n        out.getUsedRange()?.clear();\n\n    }\n\n\n    // Write header once\n\n    out.getRangeByIndexes(0, 0, 1, colCount).setValues([header]);\n\n    let writeRow = 1;\n\n    // ===== CHUNK LOOP =====\n\n    for (let start = 1; start <= rowCount; start += CHUNK_SIZE) {\n\n        const readRows = Math.min(CHUNK_SIZE, rowCount - start + 1);\n        const chunkRange = fullRange\n            .getCell(start, 0)\n            .getResizedRange(readRows - 1, colCount - 1);\n        const chunkValues = chunkRange.getValues();\n        const part: (string | number | boolean | Date)[][] = [];\n\n        for (let i = 0; i < chunkValues.length; i++) {\n\n            const row = chunkValues[i];\n\n            // ===== Region FILTER =====\n\n            const Region_Field = String(row[RegionIdx]);\n\n            //if (Region_Field === Region_Input) continue;      //  Skipping = 0 records\n            if (Region_Field === Region_Input){\n                \n                part.push(row)\n                \n                } \n            \n        }\n\n        // ===== WRITE CHUNK IMMEDIATELY =====\n\n        if (part.length > 0) {\n\n            out.getRangeByIndexes(writeRow, 0, part.length, colCount)\n\n                .setValues(part);\n\n            writeRow += part.length;\n\n        }\n\n        console.log(`Processed: ${start} → ${start + readRows - 1} - Filtered rows in chunk: ${part.length}`);\n\n    }\n\n    console.log(\"Completed successfully\");\n\n}\n\n","description":"","noCodeMetadata":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[{\"name\":\"Region\",\"index\":0}],\"parameterSchema\":{\"type\":\"object\",\"required\":[\"Region\"],\"properties\":{\"Region\":{\"type\":\"string\"}}},\"returnSchema\":{\"type\":\"object\",\"properties\":{}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"},{\"name\":\"Region\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}