{"version":"0.3.0","body":"\nfunction main(workbook: ExcelScript.Workbook,page: number): { rows: string, hasMore: boolean } {\n\n    const BATCH = 2000;   // copy and paste both script chunk size should be same\n    const ws = workbook.getWorksheet(\"Temp_FilteredData\");\n    const used = ws.getUsedRange();\n\n    if (!used) {\n\n        throw new Error(\"No data found in sheet\");\n\n    }\n\n    const totalRows = used.getRowCount();\n    const totalCols = used.getColumnCount();\n\n    // ✅ Header (safe)\n\n    const header = ws.getRangeByIndexes(0, 0, 1, totalCols).getValues()[0];\n\n    // 🔥 CONFIG (optional columns)\n\n    const requiredCols: string[] = [];\n\n    // Example\n    // const requiredCols = [\"Plant_ID\", \"Plant_Name\"];\n    const useCustomColumns = requiredCols.length > 0;\n\n    let colIndexMap: number[] = [];\n\n    if (useCustomColumns) {\n\n        for (let col of requiredCols) {\n\n            const idx = header.indexOf(col);\n\n            if (idx === -1) throw new Error(`Column not found: ${col}`);\n\n            colIndexMap.push(idx);\n\n        }\n\n    }\n\n    // --- PAGE CALC ---\n\n    let start = (page - 1) * BATCH + 1;\n    let end = Math.min(page * BATCH, totalRows - 1);\n\n    if (start > end) {\n\n        return { rows: \"[]\", hasMore: false };\n\n    }\n\n    const rowCount = end - start + 1;\n\n    // --- READ DATA ---\n\n    const range = ws.getRangeByIndexes(start, 0, rowCount, totalCols);\n    const rawValues = range.getValues();\n\n    let values: (string | number | boolean | Date)[][];\n\n    // 🔥 OPTIMIZED COLUMN SELECTION\n\n    if (useCustomColumns) {\n\n        values = rawValues.map(row =>\n\n            colIndexMap.map(idx => row[idx])\n\n        );\n\n    } else {\n\n        values = rawValues;\n\n    }\n\n    // --- HEADER (only first page) ---\n\n    if (page === 1) {\n\n        values.unshift(useCustomColumns ? requiredCols : header);\n\n    }\n\n    return {\n\n        rows: JSON.stringify(values),\n\n        hasMore: end < (totalRows - 1)\n\n    };\n\n}","description":"","noCodeMetadata":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[{\"name\":\"page\",\"index\":0}],\"parameterSchema\":{\"type\":\"object\",\"required\":[\"page\"],\"properties\":{\"page\":{\"type\":\"number\"}}},\"returnSchema\":{\"type\":\"object\",\"properties\":{\"result\":{\"type\":\"object\",\"properties\":{\"rows\":{\"type\":\"string\"},\"hasMore\":{\"type\":\"boolean\"}}}}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"},{\"name\":\"page\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}